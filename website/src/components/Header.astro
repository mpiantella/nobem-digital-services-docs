---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100 shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href={t.lang === 'en' ? '/en/' : '/'} class="flex items-center gap-2 group" aria-label={t.siteName}>
      <div class="w-9 h-9 rounded-lg bg-navy-600 flex items-center justify-center shadow-sm group-hover:bg-navy-700 transition-colors">
        <span class="text-gold-400 font-bold text-lg leading-none">N</span>
      </div>
      <span class="font-bold text-navy-600 text-xl tracking-tight">NOBAM</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#servicios" class="text-sm font-medium text-slate-600 hover:text-navy-600 transition-colors">
        {t.nav.services}
      </a>
      <a href="#equipo" class="text-sm font-medium text-slate-600 hover:text-navy-600 transition-colors">
        {t.nav.team}
      </a>
      <a href="#contacto" class="text-sm font-medium text-slate-600 hover:text-navy-600 transition-colors">
        {t.nav.contact}
      </a>
      <!-- Language toggle -->
      <a
        href={t.nav.langSwitchHref}
        class="text-xs font-semibold px-3 py-1.5 rounded-full border border-navy-200 text-navy-600 hover:bg-navy-50 transition-colors"
        aria-label={t.lang === 'en' ? 'Cambiar a Español' : 'Switch to English'}
      >
        {t.nav.langSwitch}
      </a>
    </div>

    <!-- Mobile: lang toggle + hamburger -->
    <div class="flex md:hidden items-center gap-3">
      <a
        href={t.nav.langSwitchHref}
        class="text-xs font-semibold px-2.5 py-1 rounded-full border border-navy-200 text-navy-600"
      >
        {t.nav.langSwitch}
      </a>
      <!-- CSS-only hamburger using checkbox trick -->
      <label for="mobile-menu-toggle" class="cursor-pointer p-1" aria-label="Menu">
        <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </label>
    </div>

  </nav>

  <!-- Mobile menu (CSS-only toggle) -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block md:hidden border-t border-slate-100 bg-white px-4 py-4 space-y-3">
    <a href="#servicios" class="block text-sm font-medium text-slate-700 hover:text-navy-600 py-1">
      {t.nav.services}
    </a>
    <a href="#equipo" class="block text-sm font-medium text-slate-700 hover:text-navy-600 py-1">
      {t.nav.team}
    </a>
    <a href="#contacto" class="block text-sm font-medium text-slate-700 hover:text-navy-600 py-1">
      {t.nav.contact}
    </a>
  </div>
</header>
