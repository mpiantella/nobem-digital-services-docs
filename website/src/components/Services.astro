---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

// Inline SVG icons keyed by service icon name
const icons: Record<string, string> = {
  crm: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
  </svg>`,
  marketing: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
  </svg>`,
  code: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
  </svg>`,
  consulting: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
  </svg>`,
};
---

<section id="servicios" class="py-20 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-navy-50 text-navy-600 text-xs font-semibold uppercase tracking-wider mb-4 border border-navy-100">
        {t.services.sectionBadge}
      </span>
      <h2 class="section-title">{t.services.title}</h2>
      <p class="section-subtitle">{t.services.subtitle}</p>
    </div>

    <!-- Service cards grid -->
    <div class="grid sm:grid-cols-2 gap-6">
      {t.services.items.map((service) => (
        <article class="card group">
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-navy-50 text-navy-600 flex items-center justify-center mb-5 group-hover:bg-navy-600 group-hover:text-white transition-all duration-300">
            <Fragment set:html={icons[service.icon]} />
          </div>

          <!-- Title -->
          <h3 class="text-lg font-bold text-slate-800 mb-3">{service.title}</h3>

          <!-- Description -->
          <p class="text-slate-500 text-sm leading-relaxed mb-4">{service.description}</p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mt-auto">
            {service.tags.map((tag) => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-600 font-medium">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
